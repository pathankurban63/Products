<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pathan Kurban Electronics</title>

<style>
body{font-family:Arial;margin:0;background:#f5f5f5;}
header{background:#007bff;color:#fff;padding:15px;text-align:center;}
input{width:90%;padding:10px;margin:15px;}
.products{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;padding:20px;}
.card{background:#fff;padding:15px;border-radius:10px;width:220px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.2);}
button{background:#28a745;color:#fff;border:none;padding:10px 20px;border-radius:5px;cursor:pointer;}
</style>

</head>
<body>

<header>
<h1>Pathan Kurban Electronics</h1>
<p>Best Electronics at Best Prices</p>
</header>

<input type="text" id="search" placeholder="Search Product..." onkeyup="searchProducts()">

<div class="products">

<div class="card">
<h3>Wireless Earbuds</h3>
<p>₹666</p>
<button onclick="buy('Wireless Earbuds')">Buy Now</button>
</div>

<div class="card">
<h3>Power Bank</h3>
<p>₹2000</p>
<button onclick="buy('Power Bank')">Buy Now</button>
</div>

<div class="card">
<h3>Selfie Stick</h3>
<p>₹299</p>
<button onclick="buy('Selfie Stick')">Buy Now</button>
</div>

</div>

<script>
function searchProducts(){
let input=document.getElementById("search").value.toLowerCase();
let cards=document.getElementsByClassName("card");
for(let i=0;i<cards.length;i++){
cards[i].style.display=cards[i].innerText.toLowerCase().includes(input)?"block":"none";
}
}

function buy(product){
window.open("https://wa.me/91930254746?text=I want to buy "+encodeURIComponent(product));
}
</script>

</body>
</html>
